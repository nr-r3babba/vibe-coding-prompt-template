# Bronte AI Sales Agent — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# HubSpot Private App Token
# Get this from: app.hubspot.com → Settings → Integrations → Private Apps
# Required scopes: crm.objects.deals.read, crm.objects.deals.write,
#   crm.objects.contacts.read, crm.objects.contacts.write,
#   crm.schemas.deals.read, crm.schemas.deals.write,
#   crm.objects.owners.read, timeline, forms
HUBSPOT_API_TOKEN=your-hubspot-private-app-token-here

# Claude API Key (for future agent use)
# Get this from: console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AWS Configuration (for meeting intelligence pipeline)
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_AUDIO_BUCKET=bronte-meeting-audio

# Slack Webhook (for agent notifications)
SLACK_WEBHOOK_URL=your-slack-webhook-url

# Gmail (for email delivery — interim until Slack confirmed)
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
